{
  "name": "hebai-ai-git-commit",
  "publisher": "hebai",
  "displayName": "AI 智能提交",
  "description": "AI 驱动的智能 Git 提交信息生成器，支持多种 AI 提供商和本地生成",
  "version": "1.0.3",
  "engines": {
    "vscode": "^1.102.0"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/hebai/ai-git-commit"
  },
  "author": {
    "name": "禾白"
  },
  "copyright": "Copyright (c) 2026 Hebai. All rights reserved.",
  "icon": "resources/icon.jpeg",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "openai",
    "claude",
    "gemini"
  ],
  "license": "MIT",
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hebai-ai-git-commit.generateCommitMessage",
		"title": "生成提交信息",
		"icon": "$(sparkle)"
      },
      {
        "command": "hebai-ai-git-commit.openSettings",
        "title": "打开 Hebai AI Git Commit 设置"
      }
    ],
    "configuration": {
      "title": "Hebai AI Git Commit",
      "properties": {
        "hebai-ai-git-commit.aiProvider": {
          "type": "string",
          "enum": [
            "openai",
            "openai-response",
            "claude",
            "gemini"
          ],
          "default": "openai",
          "description": "选择 AI 提供商",
          "markdownDescription": "选择用于生成提交信息的 AI 服务",
          "enumDescriptions": [
            "OpenAI (GPT-3.5/GPT-4)",
            "OpenAI Responses API (/v1/responses)",
            "Anthropic Claude",
            "Google Gemini"
          ]
        },
        "hebai-ai-git-commit.baseUrl": {
          "type": "string",
          "default": "",
          "description": "基础请求地址",
          "markdownDescription": "用于自定义 API 基础地址。留空则按提供商使用默认地址。可配合环境变量 `AI_BASE_URL`、`OPENAI_BASE_URL`、`CLAUDE_BASE_URL`、`GEMINI_BASE_URL`。"
        },
        "hebai-ai-git-commit.apiKey": {
          "type": "string",
          "default": "",
          "description": "AI API 密钥",
          "markdownDescription": "AI 服务的 API 密钥。建议使用环境变量：`OPENAI_API_KEY`、`CLAUDE_API_KEY`、`GEMINI_API_KEY`。"
        },
        "hebai-ai-git-commit.model": {
          "type": "string",
          "default": "gpt-3.5-turbo",
          "description": "AI 模型名称",
          "markdownDescription": "根据选择的 AI 提供商输入模型名称。可通过环境变量覆盖：`OPENAI_MODEL`、`CLAUDE_MODEL`、`GEMINI_MODEL`。"
        }
      }
    },
    "menus": {
      "scm/title": [
        {
          "command": "hebai-ai-git-commit.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "hebai-ai-git-commit.generateCommitMessage",
        "key": "ctrl+shift+g ctrl+shift+a",
        "when": "scmProvider == git"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "vsce package --no-dependencies",
    "build": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/node": "~20.19.9",
    "@types/vscode": "^1.102.0",
    "@vscode/vsce": "^3.6.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.7",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "openai": "^5.10.2"
  }
}
