{
  "name": "hebai-ai-git-commit",
  "publisher": "hebai",
  "displayName": "AI 智能提交",
  "description": "AI 驱动的智能 Git 提交信息生成器，支持多种 AI 提供商和本地生成",
  "version": "1.0.3",
  "engines": {
    "vscode": "^1.102.0"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/hebai/ai-git-commit"
  },
  "author": {
    "name": "禾白"
  },
  "copyright": "Copyright (c) 2026 Hebai. All rights reserved.",
  "icon": "resources/icon.jpeg",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "openai",
    "claude",
    "gemini"
  ],
  "license": "MIT",
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
    {
      "id": "hebai-ai-git-commit-views",
      "title": "助手管理",
      "icon": "resources/activitybar-icon.svg"
    }
    ]
  },
  "views": {
    "hebai-ai-git-commit-views": [
    {
      "id": "hebai-ai-git-commit-provider-management-view",
      "name": "助手管理",
      "icon": "resources/activitybar-icon.svg"
    }
    ]
  },
    "commands": [
      {
        "command": "hebai-ai-git-commit.generateCommitMessage",
		"title": "生成提交信息",
		"icon": "$(sparkle)"
      },
      {
        "command": "hebai-ai-git-commit.openSettings",
    "title": "打开助手管理"
	  },
	  {
		"command": "hebai-ai-git-commit.testModelConnection",
		"title": "测试当前激活配置",
		"icon": "$(beaker)"
    },
    {
    "command": "hebai-ai-git-commit.addProviderProfile",
    "title": "新增 AI 配置",
    "icon": "$(add)"
    },
    {
    "command": "hebai-ai-git-commit.editProviderProfile",
    "title": "编辑 AI 配置",
    "icon": "$(edit)"
    },
    {
    "command": "hebai-ai-git-commit.deleteProviderProfile",
    "title": "删除 AI 配置",
    "icon": "$(trash)"
    },
    {
    "command": "hebai-ai-git-commit.activateProviderProfile",
    "title": "设为当前激活配置",
    "icon": "$(check)"
    },
    {
    "command": "hebai-ai-git-commit.refreshProviderProfiles",
    "title": "刷新 AI 配置列表",
    "icon": "$(refresh)"
      }
    ],
    "configuration": {
      "title": "Hebai AI Git Commit",
      "properties": {
		"hebai-ai-git-commit.enableDebugLogs": {
		  "type": "boolean",
		  "default": false,
		  "description": "是否在输出面板中输出调试日志",
		  "markdownDescription": "控制是否将调试日志写入 `Hebai AI Git Commit` 输出面板。最终生成的提交信息和错误日志始终会输出。"
        }
      }
    },
    "menus": {
    "view/title": [
    {
      "command": "hebai-ai-git-commit.addProviderProfile",
      "when": "view == hebai-ai-git-commit-provider-management-view",
      "group": "navigation@1"
    },
    {
      "command": "hebai-ai-git-commit.testModelConnection",
      "when": "view == hebai-ai-git-commit-provider-management-view",
      "group": "navigation@2"
    },
    {
      "command": "hebai-ai-git-commit.refreshProviderProfiles",
      "when": "view == hebai-ai-git-commit-provider-management-view",
      "group": "navigation@3"
    }
    ],
    "view/item/context": [
    {
      "command": "hebai-ai-git-commit.editProviderProfile",
      "when": "view == hebai-ai-git-commit-provider-management-view && viewItem == providerProfile",
      "group": "inline@1"
    },
    {
      "command": "hebai-ai-git-commit.activateProviderProfile",
      "when": "view == hebai-ai-git-commit-provider-management-view && viewItem == providerProfile",
      "group": "inline@2"
    },
    {
      "command": "hebai-ai-git-commit.testModelConnection",
      "when": "view == hebai-ai-git-commit-provider-management-view && viewItem == providerProfile",
      "group": "inline@3"
    },
    {
      "command": "hebai-ai-git-commit.deleteProviderProfile",
      "when": "view == hebai-ai-git-commit-provider-management-view && viewItem == providerProfile",
      "group": "inline@4"
    },
    {
      "command": "hebai-ai-git-commit.editProviderProfile",
      "when": "view == hebai-ai-git-commit-provider-management-view && viewItem == providerProfileActive",
      "group": "inline@1"
    },
    {
      "command": "hebai-ai-git-commit.testModelConnection",
      "when": "view == hebai-ai-git-commit-provider-management-view && viewItem == providerProfileActive",
      "group": "inline@2"
    },
    {
      "command": "hebai-ai-git-commit.deleteProviderProfile",
      "when": "view == hebai-ai-git-commit-provider-management-view && viewItem == providerProfileActive",
      "group": "inline@3"
    }
    ],
      "scm/title": [
        {
          "command": "hebai-ai-git-commit.generateCommitMessage",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "hebai-ai-git-commit.generateCommitMessage",
        "key": "ctrl+shift+g ctrl+shift+a",
        "when": "scmProvider == git"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "vsce package --no-dependencies",
    "build": "webpack --mode production --devtool hidden-source-map"
  },
  "devDependencies": {
    "@types/node": "~20.19.9",
    "@types/vscode": "^1.102.0",
    "@vscode/vsce": "^3.6.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.99.7",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.10.0",
    "openai": "^5.10.2"
  }
}
